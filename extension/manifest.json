{
    "manifest_version": 3,
    "name": "DirectCast",
    "version": "1.0.1",
    "description": "Cast any browser tab to your TV — HDMI zero-latency or WebRTC wireless",

    "permissions": [
        "tabCapture",
        "tabs",
        "storage",
        "offscreen",
        "system.display"
    ],

    "host_permissions": [
        "<all_urls>"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "popup.html",
        "default_title": "DirectCast — Cast to TV",
        "default_icon": {
            "16": "icons/logo-16.png",
            "48": "icons/logo-48.png",
            "128": "icons/logo-128.png"
        }
    },

    "icons": {
        "16": "icons/logo-16.png",
        "48": "icons/logo-48.png",
        "128": "icons/logo-128.png"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],

    "web_accessible_resources": [
        {
            "resources": ["offscreen.html"],
            "matches": ["<all_urls>"]
        }
    ]
}